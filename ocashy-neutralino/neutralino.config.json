{
  "applicationId": "com.istanakeramik.ocashy",
  "version": "2.0.0",
  "defaultMode": "window",
  "port": 0,
  "documentRoot": "/dist/",
  "url": "/",
  "enableServer": true,
  "enableNativeAPI": true,
  "nativeAllowList": [
    "app.*",
    "os.*",
    "filesystem.*",
    "window.*",
    "events.*"
  ],
  "modes": {
    "window": {
      "title": "Ocashy — Istana Keramik",
      "width": 1280,
      "height": 800,
      "minWidth": 1024,
      "minHeight": 700,
      "center": true,
      "resizable": true,
      "maximize": true,
      "icon": "/icons/128x128.png"
    }
  },
  "cli": {
    "binaryName": "ocashy",
    "resourcesPath": "/dist/",
    "clientLibrary": "/dist/neutralino.js",
    "frontendLibrary": {
      "patchFile": "/index.html",
      "devUrl": "http://localhost:1420",
      "devCommand": "npm.cmd run dev",
      "buildCommand": "npm.cmd run build"
    },
    "binaryVersion": "6.8.0",
    "clientVersion": "6.8.0"
  }
}